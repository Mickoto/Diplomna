@article{TangentialTransversality,
    title = {On tangential transversality},
    journal = {Journal of Mathematical Analysis and Applications},
    volume = {481},
    number = {1},
    pages = {123445},
    year = {2020},
    issn = {0022-247X},
    doi = {https://doi.org/10.1016/j.jmaa.2019.123445},
    url = {https://www.sciencedirect.com/science/article/pii/S0022247X19307139},
    author = {Mira Bivas and Mikhail Krastanov and Nadezhda Ribarska},
    keywords = {Nonseparation of sets, Tangential transversality, Intersection
                properties, Lagrange multiplier rule},
    abstract = {This is the first of two closely related papers on
                transversality. Here we introduce the notion of tangential
                transversality of two closed subsets of a Banach space. It is an
                intermediate property between transversality and
                subtransversality. Using it, we obtain a variety of known results
                and some new ones in a unified way. Our proofs do not use
                variational principles and we concentrate mainly on tangential
                conditions in the primal space.},
}
